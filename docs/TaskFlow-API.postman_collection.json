{
  "info": {
    "name": "TaskFlow API",
    "description": "Employee Task & Incident Management System - Complete API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('token', body.data.accessToken);"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\":\"testuser\",\"email\":\"test@example.com\",\"password\":\"password123\",\"fullName\":\"Test User\",\"department\":\"Engineering\"}" }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "const body = pm.response.json();",
            "pm.collectionVariables.set('token', body.data.accessToken);",
            "pm.test('Has token', () => pm.expect(body.data.accessToken).to.be.a('string'));"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"usernameOrEmail\":\"admin\",\"password\":\"admin123\"}" }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/tasks",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"title\":\"Fix critical login bug\",\"description\":\"Users cannot login on mobile browsers\",\"type\":\"BUG\",\"priority\":\"CRITICAL\",\"dueDate\":\"2025-12-31\",\"tags\":\"auth,mobile,critical\"}" }
          }
        },
        {
          "name": "Get All Tasks (with filters)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks?status=OPEN&priority=HIGH&page=0&size=10&sort=createdAt,desc",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tasks"],
              "query": [
                { "key": "status", "value": "OPEN" },
                { "key": "priority", "value": "HIGH" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "createdAt,desc" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Task by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tasks/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/tasks/1/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"status\":\"IN_PROGRESS\"}" }
          }
        },
        {
          "name": "Search Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks?search=login&page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "tasks"],
              "query": [
                { "key": "search", "value": "login" },
                { "key": "page", "value": "0" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tasks/dashboard/stats",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/v1/tasks/1/comments",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\"content\":\"Investigated the issue. Root cause found in session management.\"}" }
          }
        },
        {
          "name": "Get Comments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tasks/1/comments?page=0&size=10",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Get Task History",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/tasks/1/history",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "List All Users (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
